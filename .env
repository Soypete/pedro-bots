# 1Password secret references — safe to commit, no real values here.
# Local dev: op run --env-file=.env -- <command>  (or use: pixi run monitor/suggest/export)
# K8s: secrets loaded via OpenBao

# Reddit API
REDDIT_CLIENT_ID=op://pedro/reddit_client_id/password
REDDIT_CLIENT_SECRET=op://pedro/reddit_client_secret/password
REDDIT_USER_AGENT=RedditWatch/1.0

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=op://pedro/twilio cred/credential
TWILIO_AUTH_TOKEN=op://pedro/twilio_auth/credential
TWILIO_FROM_NUMBER=whatsapp:+14155238886
TWILIO_TO_NUMBER=op://pedro/whatapp_number/credential

# Supabase (connection pooler URL — same format as Go services)
POSTGRES_URL=op://pedro/POSTGRES_URL/credential

# Config (non-secret — edit directly)
LLAMA_CPP_BASE_URL=http://pedrogpt:8080/v1
LLAMA_CPP_MODEL=qwen3-coder-30b
LOG_LEVEL=INFO
